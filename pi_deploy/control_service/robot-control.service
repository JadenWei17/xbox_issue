[Unit]
Description=Robot low-latency control service
After=network.target dev-ttyACM0.device
Wants=network.target

[Service]
Type=simple
User=sws3009b2
WorkingDirectory=/home/sws3009b2/robot/control_service
ExecStart=/home/sws3009b2/robot/.venv/bin/python main.py
Environment=PYTHONUNBUFFERED=1
Restart=on-failure
RestartSec=1
Nice=-10
OOMScoreAdjust=-500
KillSignal=SIGINT
TimeoutStopSec=5

[Install]
WantedBy=multi-user.target
